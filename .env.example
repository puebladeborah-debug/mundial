# En local no necesitas nada de esto: si estas variables no existen,
# la app guarda los marcadores en data/scores.local.json automáticamente.
#
# En producción (Vercel), crea una base de datos Redis gratuita:
#   Dashboard del proyecto -> Storage -> Create Database -> Redis -> Connect
# Vercel inyecta las variables solo automáticamente al conectarla; no hace
# falta copiarlas a mano salvo que uses otro proveedor de Redis/Upstash.

KV_REST_API_URL=
KV_REST_API_TOKEN=
